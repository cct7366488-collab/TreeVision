{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://treevision.example.com/schemas/analysis_result.canopyseg.schema.json",
  "title": "CanopySeg Analysis Result",
  "type": "object",
  "required": [
    "image_id",
    "model_id",
    "model_version",
    "metrics"
  ],
  "properties": {
    "image_id": {"type": "string", "format": "uuid"},
    "model_id": {"type": "string", "const": "CanopySeg"},
    "model_version": {"type": "string"},
    "mask_uri": {"type": "string", "format": "uri"},
    "metrics": {
      "type": "object",
      "required": [
        "canopy_area_px",
        "canopy_ratio",
        "veg_cover_ratio",
        "green_ratio",
        "yellow_ratio",
        "brown_ratio"
      ],
      "properties": {
        "canopy_area_px": {"type": "integer", "minimum": 0},
        "canopy_ratio": {"type": "number", "minimum": 0, "maximum": 1},
        "veg_cover_ratio": {"type": "number", "minimum": 0, "maximum": 1},
        "green_ratio": {"type": "number", "minimum": 0, "maximum": 1},
        "yellow_ratio": {"type": "number", "minimum": 0, "maximum": 1},
        "brown_ratio": {"type": "number", "minimum": 0, "maximum": 1},
        "abnormal_hotspots": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["bbox", "class", "area_ratio"],
            "properties": {
              "bbox": {
                "type": "array",
                "items": {"type": "number"},
                "minItems": 4,
                "maxItems": 4
              },
              "class": {"type": "string", "enum": ["yellow", "brown"]},
              "area_ratio": {"type": "number", "minimum": 0, "maximum": 1}
            }
          }
        }
      }
    }
  }
}
