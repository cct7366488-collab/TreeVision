{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://treevision.example.com/schemas/image_metadata.schema.json",
  "title": "TreeVision Image Metadata",
  "description": "影像上傳時必須附帶的 metadata 結構（v0.2）。tree_id/site_id 改採既有試驗碼；新增試驗設計層 FK（plot/campaign/treatment/station）；capture_type 與 view 擴充整株/尺度物。見 ADR-0003、ADR-0005。",
  "type": "object",
  "required": [
    "tree_id",
    "site_id",
    "capture_type",
    "capture_datetime",
    "view",
    "device_id"
  ],
  "properties": {
    "image_id": {
      "type": ["string", "null"],
      "description": "影像主鍵（主表用；上傳時由系統指派，可省略）。UUID 或業務鍵如 img_DXS_0001"
    },
    "tree_id": {
      "type": "string",
      "pattern": "^[0-9]{3,6}-(C0|P1|F150|P1F150)-[0-9]{3}$",
      "description": "樣木 FK，例 115121-C0-001"
    },
    "site_id": {
      "type": "string",
      "pattern": "^[0-9]{1,3}-[0-9]{1,3}-[0-9]{1,3}$",
      "description": "場域 FK，例 115-12-1"
    },
    "plot_id": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{1,3}-[0-9]{1,3}-[0-9]{1,3}\\.(C0|P1|F150|P1F150)$",
      "description": "試驗單元 FK（選填）"
    },
    "treatment_id": {
      "type": ["string", "null"],
      "enum": ["C0", "P1", "F150", "P1F150", null],
      "description": "處理組 FK（選填）"
    },
    "campaign_id": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{1,3}-[0-9]{1,3}-[0-9]{1,3}_[0-9]{3}Q[1-4]$",
      "description": "採集場次 FK（選填）"
    },
    "station_id": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{3,6}-(C0|P1|F150|P1F150)-[0-9]{3}\\.(north_side|east_side|leaf_macro|top_view|south_side|west_side|pruning_site_close_up)$",
      "description": "固定攝點 FK（選填；試驗影像建議填）"
    },
    "capture_type": {
      "type": "string",
      "enum": ["canopy", "leaf_closeup", "whole_plant", "scale_ref"],
      "description": "影像類型。whole_plant=整株、scale_ref=尺度物驗證（ADR-0003 §五）"
    },
    "capture_datetime": {
      "type": "string",
      "format": "date-time"
    },
    "view": {
      "type": "string",
      "enum": ["north", "south", "east", "west", "overhead", "handheld", "whole_north", "whole_south", "whole_east", "whole_west"],
      "description": "視角。whole_* 為整株固定攝點方位（ADR-0003 §五）"
    },
    "device_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "gps_lat": {
      "type": ["number", "null"],
      "minimum": -90,
      "maximum": 90
    },
    "gps_lon": {
      "type": ["number", "null"],
      "minimum": -180,
      "maximum": 180
    },
    "scale_object_type": {
      "type": ["string", "null"],
      "enum": ["a4_grid", "coin_5twd", "coin_10twd", "ruler", "other", null]
    },
    "scale_object_size_mm": {
      "type": ["number", "null"],
      "exclusiveMinimum": 0
    },
    "has_color_card": {
      "type": ["boolean", "null"]
    },
    "weather": {
      "type": ["string", "null"],
      "enum": ["sunny", "cloudy", "overcast", "rain", "fog", null]
    },
    "note": {
      "type": ["string", "null"],
      "maxLength": 1000
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "capture_type": { "const": "leaf_closeup" } }
      },
      "then": {
        "required": ["scale_object_type", "scale_object_size_mm"]
      }
    }
  ],
  "additionalProperties": false
}
