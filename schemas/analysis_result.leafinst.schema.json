{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://treevision.example.com/schemas/analysis_result.leafinst.schema.json",
  "title": "LeafInst Analysis Result",
  "type": "object",
  "required": ["image_id", "model_id", "model_version", "leaves", "scale_objects", "mm_per_pixel"],
  "properties": {
    "image_id": {"type": "string", "format": "uuid"},
    "model_id": {"type": "string", "const": "LeafInst"},
    "model_version": {"type": "string"},
    "mm_per_pixel": {"type": "number", "exclusiveMinimum": 0},
    "scale_objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "bbox", "ref_size_mm", "confidence"],
        "properties": {
          "type": {"type": "string", "enum": ["a4_grid", "coin_5twd", "coin_10twd", "ruler"]},
          "bbox": {"type": "array", "items": {"type": "number"}, "minItems": 4, "maxItems": 4},
          "ref_size_mm": {"type": "number", "exclusiveMinimum": 0},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "leaves": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["instance_id", "polygon", "bbox", "area_px", "area_cm2"],
        "properties": {
          "instance_id": {"type": "integer"},
          "polygon": {
            "type": "array",
            "items": {"type": "array", "items": {"type": "number"}, "minItems": 2, "maxItems": 2}
          },
          "bbox": {"type": "array", "items": {"type": "number"}, "minItems": 4, "maxItems": 4},
          "area_px": {"type": "integer", "minimum": 0},
          "area_cm2": {"type": "number", "minimum": 0},
          "length_mm": {"type": "number", "minimum": 0},
          "width_mm": {"type": "number", "minimum": 0},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    }
  }
}
