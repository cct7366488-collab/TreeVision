{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://treevision.example.com/schemas/site_registry.schema.json",
  "title": "TreeVision Site Registry（場域）",
  "description": "場域層級實體（事業區+林班+作業列區）。對齊既有『土肉桂生長調查記錄表.xlsx』樣區工作表，並擴充 ADR-0002 之四樣區定錨資料。site_id 採林班作業列區 dash 編號（115-12-1 等），短碼為別名。",
  "type": "object",
  "required": ["site_id", "name", "owner", "region", "gps_datum", "centroid_lat", "centroid_lon"],
  "properties": {
    "site_id": {
      "type": "string",
      "pattern": "^[0-9]{1,3}-[0-9]{1,3}-[0-9]{1,3}$",
      "description": "場域鍵＝林班作業列區編號，例 115-12-1、8-1-1"
    },
    "site_code_short": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{3,6}$",
      "description": "資料檔短碼別名，例 115121、811、8110、117218"
    },
    "plot_type": {
      "type": ["string", "null"],
      "enum": ["永久樣區", "臨時樣區", null],
      "description": "樣區型態（XLSX 代碼表）"
    },
    "name": {"type": "string", "description": "場域中文名"},
    "owner": {"type": "string", "description": "主管機關，如 林業及自然保育署臺中分署"},
    "region": {"type": "string", "description": "縣市"},
    "township": {"type": ["string", "null"], "description": "鄉鎮"},
    "location": {"type": ["string", "null"], "description": "場域/地點"},
    "forest_district": {"type": ["string", "null"], "description": "事業區，如 大安溪 / 八仙山"},
    "compartment": {"type": ["string", "null"], "description": "林班"},
    "sub_lot_no": {"type": ["string", "null"], "description": "假地號"},
    "gps_datum": {
      "type": "string",
      "enum": ["WGS84", "TWD97"],
      "description": "座標基準（XLSX 代碼表）"
    },
    "centroid_lat": {
      "type": "number",
      "description": "場域中心緯度。DB 存原始值；遮蔽於 API serialization（ADR-0001 議題5）"
    },
    "centroid_lon": {"type": "number", "description": "場域中心經度"},
    "elevation_m": {"type": ["number", "null"], "description": "海拔高（公尺）"},
    "slope_deg": {"type": ["number", "null"], "minimum": 0, "maximum": 90, "description": "坡度（度）"},
    "aspect": {
      "type": ["string", "null"],
      "enum": ["N", "NE", "E", "SE", "S", "SW", "W", "NW", "平地", null],
      "description": "坡向（XLSX 代碼表）"
    },
    "slope_position": {
      "type": ["string", "null"],
      "enum": ["谷", "下坡", "中坡", "上坡", "稜", "平地", null],
      "description": "坡位（XLSX 代碼表）"
    },
    "area_ha": {
      "type": ["number", "null"],
      "exclusiveMinimum": 0,
      "description": "作業列區總面積（公頃）。115-12-1=0.5、117-28-1=0.355、8-1-1=0.2372、8-1-10=0.4482"
    },
    "age_stage": {
      "type": ["string", "null"],
      "description": "林齡階段描述，如『15-20年生成熟林』『1-2年生幼齡林』"
    },
    "age_class": {
      "type": ["string", "null"],
      "enum": ["mature", "juvenile", null],
      "description": "林齡粗分類（成熟林/幼齡林），便於程式篩選"
    },
    "planted_date": {
      "type": ["string", "null"],
      "description": "栽植年月。115-12-1=2010-10、117-28-1=2025-04、8-1-1/8-1-10=2024-03（YYYY-MM 或 YYYY-MM-DD）"
    },
    "established_date": {"type": ["string", "null"], "format": "date", "description": "樣區建置日期"},
    "surveyor": {"type": ["string", "null"], "description": "調查員"},
    "forest_type": {"type": ["string", "null"], "description": "林型"},
    "note": {"type": ["string", "null"], "maxLength": 1000}
  },
  "additionalProperties": false
}
