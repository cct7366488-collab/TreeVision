{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://treevision.example.com/schemas/disturbance.schema.json",
  "title": "TreeVision Disturbance（干擾事件）",
  "description": "干擾/危害事件。對齊既有 XLSX『干擾』工作表。記錄干擾型態、嚴重度與受影響範圍。",
  "type": "object",
  "required": ["survey_date", "site_id", "disturbance_type", "severity_1_5"],
  "properties": {
    "survey_date": {"type": "string", "format": "date", "description": "調查日期"},
    "site_id": {
      "type": "string",
      "pattern": "^[0-9]{1,3}-[0-9]{1,3}-[0-9]{1,3}$",
      "description": "所屬場域 FK"
    },
    "disturbance_type": {
      "type": "string",
      "enum": ["颱風", "豪雨/崩塌", "落石", "獸害", "病蟲害", "砍伐", "人為踩踏", "火災", "其他"],
      "description": "干擾型態（XLSX 代碼表）"
    },
    "severity_1_5": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "嚴重程度（1 非常輕微 ~ 5 極嚴重；XLSX 代碼表）"
    },
    "affected_tree_count": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "受影響的樹木株數"
    },
    "area_m2": {
      "type": ["number", "null"],
      "minimum": 0,
      "description": "受影響面積（m²）"
    },
    "note": {"type": ["string", "null"], "maxLength": 1000}
  },
  "additionalProperties": false
}
