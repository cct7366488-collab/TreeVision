{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://treevision.example.com/schemas/soil_environment.schema.json",
  "title": "TreeVision Soil & Environment（土壤與環境）",
  "description": "土壤與環境觀測。對齊既有 XLSX『土壤&環境』工作表。施肥試驗前後各取一次，供土壤肥力變化比較。",
  "type": "object",
  "required": ["survey_date", "site_id"],
  "properties": {
    "survey_date": {"type": "string", "format": "date", "description": "調查日期"},
    "site_id": {
      "type": "string",
      "pattern": "^[0-9]{1,3}-[0-9]{1,3}-[0-9]{1,3}$",
      "description": "所屬場域 FK"
    },
    "soil_temp_c": {"type": ["number", "null"], "description": "土壤溫度（°C）"},
    "soil_moisture_pct": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 100,
      "description": "土壤濕度（%）"
    },
    "ph": {
      "type": ["number", "null"],
      "minimum": 2.5,
      "maximum": 9.5,
      "description": "pH 值"
    },
    "conductivity": {"type": ["number", "null"], "description": "土壤電導度"},
    "texture": {
      "type": ["string", "null"],
      "enum": ["Sand", "Loamy sand", "Sandy loam", "Loam", "Silt loam", "Silt", "Sandy clay loam", "Clay loam", "Silty clay loam", "Sandy clay", "Silty clay", "Clay", null],
      "description": "土壤質地（XLSX 代碼表）"
    },
    "bulk_density_g_cm3": {"type": ["number", "null"], "minimum": 0, "description": "土壤體積密度（g/cm³）"},
    "litter_depth_cm": {"type": ["number", "null"], "minimum": 0, "description": "枯落物層厚度（cm）"},
    "ground_cover_type": {
      "type": ["string", "null"],
      "enum": ["裸地", "草本", "灌木", "枯落物", "岩石", "苔蘚/地衣", null],
      "description": "地表覆蓋類型（XLSX 代碼表）"
    },
    "photo": {"type": ["string", "null"], "description": "照片檔名或 storage_uri"},
    "note": {"type": ["string", "null"], "maxLength": 1000}
  },
  "additionalProperties": false
}
