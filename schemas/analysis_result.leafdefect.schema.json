{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://treevision.example.com/schemas/analysis_result.leafdefect.schema.json",
  "title": "LeafDefect Analysis Result",
  "description": "葉片病徵分析結果。健康分數採兩階段設計（ADR-0001 議題 3）：v1 必填 health_score_global（全域權重）、health_score_species 為 v1.5+ 樹種校正後填入，v1 留 null。",
  "type": "object",
  "required": ["image_id", "model_id", "model_version", "per_leaf"],
  "properties": {
    "image_id": {"type": "string", "format": "uuid"},
    "model_id": {"type": "string", "const": "LeafDefect"},
    "model_version": {"type": "string"},
    "per_leaf": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "instance_id",
          "lesion_ratio",
          "chlorosis_ratio",
          "necrosis_ratio",
          "hole_ratio",
          "health_score_global",
          "health_grade"
        ],
        "properties": {
          "instance_id": {"type": "integer"},
          "lesion_ratio": {"type": "number", "minimum": 0, "maximum": 1},
          "chlorosis_ratio": {"type": "number", "minimum": 0, "maximum": 1},
          "necrosis_ratio": {"type": "number", "minimum": 0, "maximum": 1},
          "hole_ratio": {"type": "number", "minimum": 0, "maximum": 1},
          "total_defect_ratio": {"type": "number", "minimum": 0, "maximum": 1},
          "health_score_global": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "全域權重健康分數（v1 必填）"
          },
          "health_score_species": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 100,
            "description": "樹種特化權重健康分數（v1 為 null，v1.5+ 填入）"
          },
          "health_grade": {"type": "string", "enum": ["A", "B", "C", "D", "E"]}
        }
      }
    },
    "image_summary": {
      "type": "object",
      "required": ["health_score_global_mean", "health_grade"],
      "properties": {
        "lesion_ratio_mean": {"type": "number"},
        "chlorosis_ratio_mean": {"type": "number"},
        "necrosis_ratio_mean": {"type": "number"},
        "hole_ratio_mean": {"type": "number"},
        "total_defect_ratio_mean": {"type": "number"},
        "health_score_global_mean": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "全域權重健康分數的影像平均（v1 必填）"
        },
        "health_score_species_mean": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 100,
          "description": "樹種特化權重健康分數的影像平均（v1 為 null）"
        },
        "health_grade": {"type": "string", "enum": ["A", "B", "C", "D", "E"]}
      }
    }
  }
}
