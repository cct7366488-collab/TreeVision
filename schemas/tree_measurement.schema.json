{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://treevision.example.com/schemas/tree_measurement.schema.json",
  "title": "TreeVision Tree Measurement（樣木歷次量測）",
  "description": "樣木每場次（季別）之人工/影像基準量測。對齊既有 XLSX『樹木_歷次』與『土肉桂試驗_長格式』表。以 measure_date 為事件（不限頻率，依官方季配）。取代 v0.1 tree_daily_summary 中與人工量測重疊之部分（影像衍生指標另見 tree_image_metric_daily）。",
  "type": "object",
  "required": ["tree_id", "season"],
  "properties": {
    "tree_id": {
      "type": "string",
      "pattern": "^[0-9]{3,6}-(C0|P1|F150|P1F150)-[0-9]{3}$",
      "description": "樣木 FK，例 115121-C0-001"
    },
    "campaign_id": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{1,3}-[0-9]{1,3}-[0-9]{1,3}_[0-9]{3}Q[1-4]$",
      "description": "採集場次 FK（選填）"
    },
    "season": {
      "type": "string",
      "pattern": "^[0-9]{3}Q[1-4]$",
      "description": "季別，例 114Q3、114Q4、115Q1"
    },
    "measure_date": {
      "type": ["string", "null"],
      "format": "date",
      "description": "量測日期（或推定季末日）"
    },
    "stem_seq": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "莖序（多幹個體；主幹=1，分幹 2,3...；對齊長格式 -s2/-s3）"
    },
    "measure_part": {
      "type": ["string", "null"],
      "enum": ["胸徑", "地徑", null],
      "description": "量測部位（幼齡林多採地徑，成熟林採胸徑1.3m）"
    },
    "dbh_cm": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 200,
      "description": "胸徑或地徑（cm），對齊長格式『直徑_cm』"
    },
    "height_m": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 80,
      "description": "樹高（m）"
    },
    "crown_w1_m": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 40,
      "description": "冠幅 NS（m）"
    },
    "crown_w2_m": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 40,
      "description": "冠幅 EW（m）"
    },
    "crown_class": {
      "type": ["string", "null"],
      "enum": ["優勢", "共優勢", "次冠層", "被壓", null],
      "description": "冠層階級（XLSX 代碼表）"
    },
    "health_grade_subjective_1_5": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 5,
      "description": "健康度主觀評分（1=差 ~ 5=佳）"
    },
    "damage_1": {
      "type": ["string", "null"],
      "enum": ["無", "折幹/倒伏", "傷皮/刮傷", "中心空洞", "病蟲危害", "土壤擾動", "人為干擾", "其他", null],
      "description": "損傷/干擾跡象 1（XLSX 代碼表）"
    },
    "damage_2": {
      "type": ["string", "null"],
      "enum": ["無", "折幹/倒伏", "傷皮/刮傷", "中心空洞", "病蟲危害", "土壤擾動", "人為干擾", "其他", null],
      "description": "損傷/干擾跡象 2"
    },
    "liana_cover_pct": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 100,
      "description": "纏繞藤本（liana）覆蓋 %"
    },
    "basal_area_m2": {
      "type": ["number", "null"],
      "minimum": 0,
      "description": "胸高斷面積（m²），由 dbh 換算"
    },
    "volume_m3": {
      "type": ["number", "null"],
      "minimum": 0,
      "description": "材積（對齊長格式『材積_原表』）"
    },
    "growth_increment": {
      "type": ["number", "null"],
      "description": "相對前一場次之生長量（長格式『生長量_原表』）"
    },
    "status": {
      "type": ["string", "null"],
      "enum": ["存活", "枯立", "倒伏", "缺測", "死亡", null],
      "description": "本場次個體狀態（含長格式『死亡』）"
    },
    "measured_by": {"type": ["string", "null"], "description": "量測者"},
    "note": {"type": ["string", "null"], "maxLength": 1000}
  },
  "additionalProperties": false
}
