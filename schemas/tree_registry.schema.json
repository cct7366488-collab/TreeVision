{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://treevision.example.com/schemas/tree_registry.schema.json",
  "title": "TreeVision Tree Registry（樣木個體）",
  "description": "樣木個體靜態身分。對齊既有 XLSX 樹木工作表並補試驗 FK。tree_id 採既有碼 <樣區短碼>-<處理>-<序號>（例 115121-C0-001）；多幹個體以 stem_seq 表莖序（長格式 -s2/-s3）。動態量測（胸徑/樹高/健康）見 tree_measurement。",
  "type": "object",
  "required": ["tree_id", "site_id", "plot_id", "treatment_id", "tree_no", "species_zh"],
  "properties": {
    "tree_id": {
      "type": "string",
      "pattern": "^[0-9]{3,6}-(C0|P1|F150|P1F150)-[0-9]{3}$",
      "description": "樣木鍵＝<樣區短碼>-<處理>-<序號>，例 115121-C0-001"
    },
    "site_id": {
      "type": "string",
      "pattern": "^[0-9]{1,3}-[0-9]{1,3}-[0-9]{1,3}$",
      "description": "所屬場域 FK"
    },
    "plot_id": {
      "type": "string",
      "pattern": "^[0-9]{1,3}-[0-9]{1,3}-[0-9]{1,3}\\.(C0|P1|F150|P1F150)$",
      "description": "所屬試驗單元 FK"
    },
    "treatment_id": {
      "type": "string",
      "enum": ["C0", "P1", "F150", "P1F150"],
      "description": "處理組 FK"
    },
    "tree_no": {
      "type": "integer",
      "minimum": 1,
      "description": "處理格內樣木編號（1~30）"
    },
    "tree_tag": {
      "type": ["string", "null"],
      "description": "現場標籤號（油漆/金屬牌）"
    },
    "is_multistem": {
      "type": ["boolean", "null"],
      "description": "是否多幹"
    },
    "stem_count": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "莖數（多幹個體之主幹+分幹總數）"
    },
    "species_zh": {"type": "string", "description": "中文種名，如 土肉桂"},
    "species_sci": {
      "type": ["string", "null"],
      "description": "學名，如 Cinnamomum osmophloeum"
    },
    "growth_stage": {
      "type": ["string", "null"],
      "enum": ["幼樹", "小徑木", "成樹", null],
      "description": "生長階段（XLSX 代碼表）"
    },
    "status": {
      "type": ["string", "null"],
      "enum": ["存活", "枯立", "倒伏", "缺測", null],
      "description": "個體狀態（XLSX 代碼表）。長格式『狀態』含『死亡』者對應 枯立/倒伏 視情況"
    },
    "planted_date": {
      "type": ["string", "null"],
      "description": "栽植年月（多沿用 site 層級值）"
    },
    "lat": {"type": ["number", "null"], "description": "GPS 緯度；DB 存原始、API 遮蔽（ADR-0001 議題5）"},
    "lon": {"type": ["number", "null"], "description": "GPS 經度"},
    "x_m": {"type": ["number", "null"], "description": "樣區內相對座標 X（公尺）"},
    "y_m": {"type": ["number", "null"], "description": "樣區內相對座標 Y（公尺）"},
    "is_protected": {"type": ["boolean", "null"], "description": "是否保護樹"},
    "note": {"type": ["string", "null"], "maxLength": 1000},
    "created_at": {"type": ["string", "null"], "format": "date-time"},
    "updated_at": {"type": ["string", "null"], "format": "date-time"}
  },
  "additionalProperties": false
}
